# ============================================================================
# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).
#
# PRODUCTION (NODE_ENV=production) — the app REFUSES to boot if any of these
# still hold dev/default values (enforced in src/config/env.validation.ts):
#   • FRONTEND_URL / GOOGLE_CALLBACK_URL / DOMAIN contain localhost/127.0.0.1/0.0.0.0/an internal IP
#   • DB_PASSWORD = "postgres"        → set a strong unique value
#   • S3_ACCESS_KEY / S3_SECRET_KEY = "minioadmin"
#   • JWT_ACCESS_SECRET = JWT_REFRESH_SECRET (must differ; ≥32 chars each)
#   • ADMIN_PASSWORD left at the sample value
# Generate secrets with:  openssl rand -base64 32
# ============================================================================

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=quizdb
# TLS is opt-in. Set DB_SSL=true for cloud-managed Postgres (Railway, Supabase, etc.)
# DB_SSL=true
# DB_SSL_CA=          # PEM of the CA cert for verified connections (recommended)
# DB_SSL_REJECT_UNAUTHORIZED=false  # use only with self-signed certs on private networks

# JWT (secrets must be at least 32 characters — validated at boot)
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Mail (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="QuizApp <no-reply@quizapp.io>"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# S3 / Minio
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quizapp

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Telegram Bot (optional — bot only starts if token is provided)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=QuizAppBot

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Admin seed
ADMIN_EMAIL=admin@quizapp.io
ADMIN_PASSWORD=change_me_strong_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
