# ============================================================
# CheckLab Production Environment — copy to .env and fill in
# Used by docker-compose.yml on the production server
# ============================================================

# Domain (used by nginx SSL and Google OAuth callback)
DOMAIN=yourdomain.com

# Database
DB_NAME=checklabdb
DB_USERNAME=postgres
DB_PASSWORD=choose_a_strong_password

# Telegram (frontend build arg — bot username shown in the UI)
TELEGRAM_BOT_USERNAME=YourBotName

# Image registry prefix for pre-built images (CI/CD deploys).
# Local builds can leave this unset (defaults to "checklab").
# IMAGE_PREFIX=ghcr.io/<owner>/<repo>

# Frontend build args (passed to Docker build)
NEXT_PUBLIC_API_URL=/api
